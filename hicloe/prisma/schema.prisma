// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// HiLCoE Scheduler — full domain schema (Prisma 7)
// Tables/columns mapped to snake_case. Runtime uses @prisma/adapter-pg (Supabase pooler);
// migrations use DIRECT_URL (5432). See prisma.config.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────── Identity & access ──────────────────────────

enum UserStatus {
  INVITED // registered by admin, no password yet
  ACTIVE
  SUSPENDED
}

model User {
  id           String     @id @default(uuid()) @map("id")
  fullName     String     @map("full_name")
  email        String     @unique
  passwordHash String?    @map("password_hash") // null until activation
  status       UserStatus @default(INVITED)
  // ABAC attributes, e.g. { "programIds": [...], "batchIds": [...], "instructorId": "..." }
  attributes   Json       @default("{}")
  failedLogins Int        @default(0) @map("failed_logins")
  lockedUntil  DateTime?  @map("locked_until")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  roles         Role[]         @relation("UserRoles")
  sessions      AuthSession[]
  tokens        AuthToken[]
  auditLogs     AuditLog[]
  instructor    Instructor?
  verifications Verification[]
  importBatches ImportBatch[]
  scheduleVersions ScheduleVersion[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // SUPER_ADMIN, SCHEDULER, VERIFIER, REGISTRAR, INSTRUCTOR, VIEWER (+ custom)
  description String?
  system      Boolean      @default(false) // system roles cannot be deleted
  permissions Permission[] @relation("RolePermissions")
  users       User[]       @relation("UserRoles")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid())
  action   String // e.g. "schedule:publish", "users:manage"
  resource String @default("*") // reserved for finer scoping later
  roles    Role[] @relation("RolePermissions")

  @@unique([action, resource])
  @@map("permissions")
}

model AuthSession {
  id        String   @id // sha256 hash of the opaque cookie token
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  lastSeen  DateTime @default(now()) @map("last_seen")
  ip        String?
  userAgent String?  @map("user_agent")

  @@index([userId])
  @@map("auth_sessions")
}

enum TokenPurpose {
  ACTIVATION
  PASSWORD_RESET
}

model AuthToken {
  id        String       @id @default(uuid())
  tokenHash String       @unique @map("token_hash") // sha256; raw token only ever emailed
  purpose   TokenPurpose
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime     @map("expires_at")
  usedAt    DateTime?    @map("used_at")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId, purpose])
  @@map("auth_tokens")
}

// ────────────────────────── Academic structure ──────────────────────────

enum Audience {
  UG
  PG
}

enum PeriodType {
  SEMESTER
  TERM
}

model Program {
  id      String   @id @default(uuid())
  code    String   @unique // "SE-UG", "CS-PG"
  name    String
  level   Audience
  batches Batch[]

  @@map("programs")
}

model AcademicPeriod {
  id        String     @id @default(uuid())
  name      String // "2026 Semester I", "2026 Term 3"
  type      PeriodType
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  batches   Batch[]
  schedules Schedule[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@unique([name, type])
  @@map("academic_periods")
}

model Batch {
  id        String         @id @default(uuid())
  name      String // "Batch 12"
  programId String         @map("program_id")
  program   Program        @relation(fields: [programId], references: [id])
  periodId  String         @map("period_id")
  period    AcademicPeriod @relation(fields: [periodId], references: [id])
  sections  Section[]
  offerings CourseOffering[]
  deletedAt DateTime?      @map("deleted_at") // soft delete

  @@unique([name, programId, periodId])
  @@map("batches")
}

model Section {
  id        String     @id @default(uuid())
  name      String // "A", "B"
  batchId   String     @map("batch_id")
  batch     Batch      @relation(fields: [batchId], references: [id])
  headcount Int
  groups    LabGroup[]
  students  Student[]
  offerings CourseOffering[] @relation("OfferingSections")
  deletedAt DateTime?  @map("deleted_at")

  @@unique([name, batchId])
  @@map("sections")
}

model LabGroup {
  id        String    @id @default(uuid())
  name      String // "G1", "G2"
  sectionId String    @map("section_id")
  section   Section   @relation(fields: [sectionId], references: [id])
  headcount Int
  students  Student[]
  deletedAt DateTime? @map("deleted_at")

  @@unique([name, sectionId])
  @@map("lab_groups")
}

model Student {
  id        String    @id @default(uuid())
  fullName  String    @map("full_name")
  email     String    @unique
  sectionId String    @map("section_id")
  section   Section   @relation(fields: [sectionId], references: [id])
  groupId   String?   @map("group_id")
  group     LabGroup? @relation(fields: [groupId], references: [id])
  deletedAt DateTime? @map("deleted_at")

  @@map("students")
}

model Course {
  id                     String  @id @default(uuid())
  code                   String  @unique // "CS301"
  name                   String
  lectureCreditHrs       Int     @map("lecture_credit_hrs")
  labCreditHrs           Int     @map("lab_credit_hrs")
  lectureSessionsPerWeek Int     @map("lecture_sessions_per_week") // derived from credit rule, overridable
  labSessionsPerWeek     Int     @map("lab_sessions_per_week")
  labNeedsDoublePeriod   Boolean @default(false) @map("lab_needs_double_period")
  offerings              CourseOffering[]
  instructorPool         Instructor[] @relation("CoursePool")
  deletedAt              DateTime? @map("deleted_at")

  @@map("courses")
}

model CourseOffering {
  id            String   @id @default(uuid())
  courseId      String   @map("course_id")
  course        Course   @relation(fields: [courseId], references: [id])
  batchId       String   @map("batch_id")
  batch         Batch    @relation(fields: [batchId], references: [id])
  sections      Section[] @relation("OfferingSections")
  sharedLecture Boolean  @default(false) @map("shared_lecture") // all sections attend one lecture session
  instructors   OfferingInstructor[]
  sessions      ScheduleSession[]
  deletedAt     DateTime? @map("deleted_at")

  @@unique([courseId, batchId])
  @@map("course_offerings")
}

enum Employment {
  FULL_TIME
  PART_TIME
}

model Instructor {
  id           String     @id @default(uuid())
  userId       String?    @unique @map("user_id") // optional link to a login account
  user         User?      @relation(fields: [userId], references: [id])
  fullName     String     @map("full_name")
  email        String?    @unique
  employment   Employment
  coursePool   Course[]   @relation("CoursePool")
  availability InstructorAvailability[]
  offerings    OfferingInstructor[]
  deletedAt    DateTime?  @map("deleted_at")

  @@map("instructors")
}

model OfferingInstructor {
  offeringId   String         @map("offering_id")
  offering     CourseOffering @relation(fields: [offeringId], references: [id])
  instructorId String         @map("instructor_id")
  instructor   Instructor     @relation(fields: [instructorId], references: [id])
  kind         SessionKind    @default(LECTURE) // which part they teach; co-teaching = multiple rows same kind

  @@id([offeringId, instructorId, kind])
  @@map("offering_instructors")
}

enum AvailabilityStatus {
  AVAILABLE
  AVOID       // soft: schedulable but penalized (has a reason)
  UNAVAILABLE // hard: never scheduled here
}

model InstructorAvailability {
  instructorId String             @map("instructor_id")
  instructor   Instructor         @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  slotDefId    String             @map("slot_def_id")
  slotDef      SlotDef            @relation(fields: [slotDefId], references: [id], onDelete: Cascade)
  status       AvailabilityStatus @default(AVAILABLE)
  reason       String?

  @@id([instructorId, slotDefId])
  @@map("instructor_availability")
}

// ────────────────────────── Time & space ──────────────────────────

model SlotTemplate {
  id        String    @id @default(uuid())
  name      String    @unique // "Standard 2026 (6 periods)"
  active    Boolean   @default(false)
  slots     SlotDef[]
  schedules Schedule[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("slot_templates")
}

model SlotDef {
  id         String       @id @default(uuid())
  templateId String       @map("template_id")
  template   SlotTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  day        Int // 1=Mon … 7=Sun
  index      Int // period number within the day
  startTime  String       @map("start_time") // "08:00"
  endTime    String       @map("end_time") // "09:30"
  audience   Audience[] // who may be scheduled here; PG-only evening slot => [PG]
  blocked    Boolean      @default(false) // e.g. Friday P3
  assignments  Assignment[]
  availability InstructorAvailability[]

  @@unique([templateId, day, index])
  @@map("slot_defs")
}

enum RoomType {
  LECTURE
  LAB
}

model Room {
  id          String       @id @default(uuid())
  name        String       @unique
  type        RoomType
  capacity    Int
  active      Boolean      @default(true)
  assignments Assignment[]
  deletedAt   DateTime?    @map("deleted_at")

  @@map("rooms")
}

// ────────────────────────── Scheduling core ──────────────────────────

enum ScheduleState {
  DRAFT
  GENERATING
  GENERATED
  FAILED
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

model Schedule {
  id             String         @id @default(uuid())
  periodId       String         @map("period_id")
  period         AcademicPeriod @relation(fields: [periodId], references: [id])
  slotTemplateId String         @map("slot_template_id")
  slotTemplate   SlotTemplate   @relation(fields: [slotTemplateId], references: [id])
  effectiveFrom  DateTime       @map("effective_from")
  effectiveTo    DateTime       @map("effective_to")
  state          ScheduleState  @default(DRAFT)
  versions       ScheduleVersion[]
  constraintConfig ConstraintConfig?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("schedules")
}

model ScheduleVersion {
  id               String    @id @default(uuid())
  scheduleId       String    @map("schedule_id")
  schedule         Schedule  @relation(fields: [scheduleId], references: [id])
  number           Int
  createdById      String    @map("created_by_id")
  createdBy        User      @relation(fields: [createdById], references: [id])
  solverRequest    Json?     @map("solver_request") // full reproducibility
  solverResponse   Json?     @map("solver_response")
  objectivePenalty Int?      @map("objective_penalty")
  notes            String?
  sessions         ScheduleSession[]
  verifications    Verification[]
  createdAt        DateTime  @default(now()) @map("created_at")

  @@unique([scheduleId, number])
  @@map("schedule_versions")
}

enum SessionKind {
  LECTURE
  LAB
}

model ScheduleSession {
  id            String          @id @default(uuid())
  versionId     String          @map("version_id")
  version       ScheduleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  offeringId    String          @map("offering_id")
  offering      CourseOffering  @relation(fields: [offeringId], references: [id])
  kind          SessionKind
  periods       Int             @default(1) // 2 = consecutive double period
  audienceUnits Json            @map("audience_units") // [{kind:"SECTION"|"GROUP", id}]
  instructorIds Json            @map("instructor_ids") // ["..."] co-teaching set
  assignment    Assignment?

  @@map("schedule_sessions")
}

model Assignment {
  id             String          @id @default(uuid())
  sessionId      String          @unique @map("session_id")
  session        ScheduleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slotDefId      String          @map("slot_def_id")
  slotDef        SlotDef         @relation(fields: [slotDefId], references: [id])
  roomId         String          @map("room_id")
  room           Room            @relation(fields: [roomId], references: [id])
  pinned         Boolean         @default(false)
  manuallyEdited Boolean         @default(false) @map("manually_edited")

  // Hard invariant "no room double-booking within a version" is enforced by a
  // partial unique index added in prisma/sql/hardening.sql (needs version join).
  @@index([slotDefId, roomId])
  @@map("assignments")
}

model ConstraintConfig {
  id         String   @id @default(uuid())
  scheduleId String   @unique @map("schedule_id")
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  weights    Json     @default("{}") // soft-constraint weights
  options    Json     @default("{}") // e.g. instructorMaxPeriodsPerDay
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("constraint_configs")
}

// ────────────────────────── Governance ──────────────────────────

enum VerificationDecision {
  APPROVE
  REJECT
}

model Verification {
  id         String               @id @default(uuid())
  versionId  String               @map("version_id")
  version    ScheduleVersion      @relation(fields: [versionId], references: [id])
  verifierId String               @map("verifier_id")
  verifier   User                 @relation(fields: [verifierId], references: [id])
  scope      Json // e.g. { "batchIds": [...] } — what this sign-off covers
  decision   VerificationDecision
  comment    String?
  decidedAt  DateTime             @default(now()) @map("decided_at")

  @@map("verifications")
}

enum ImportSource {
  FILE
  API
}

enum ImportStatus {
  PENDING
  VALIDATED
  FAILED
  COMMITTED
}

model ImportBatch {
  id               String       @id @default(uuid())
  source           ImportSource
  fileName         String?      @map("file_name")
  uploadedById     String       @map("uploaded_by_id")
  uploadedBy       User         @relation(fields: [uploadedById], references: [id])
  parsedPayload    Json?        @map("parsed_payload")
  validationReport Json?        @map("validation_report")
  status           ImportStatus @default(PENDING)
  createdAt        DateTime     @default(now()) @map("created_at")

  @@map("import_batches")
}

// ────────────────────────── Audit (append-only, hash-chained) ──────────────────────────

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  at         DateTime @default(now())
  actorId    String?  @map("actor_id") // null = system / unauthenticated
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String // "auth.login", "schedule.publish", "authz.denied", …
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  meta       Json? // free-form: reason for denial, counts, etc.
  requestId  String?  @map("request_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  prevHash   String   @map("prev_hash")
  hash       String

  @@index([entityType, entityId])
  @@index([actorId, at])
  @@index([action, at])
  @@map("audit_logs")
}
